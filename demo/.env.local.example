# ─────────────────────────────────────────────────────────────
# 모두의 모임 — 환경변수 (.env.local 로 복사해 값 입력)
# Vercel 배포 시: Project Settings > Environment Variables 에 동일하게 등록
# ─────────────────────────────────────────────────────────────

# Supabase (DB + 회원 인증) — 대시보드 > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 (절대 NEXT_PUBLIC_ 금지, 절대 커밋 금지)
SUPABASE_SERVICE_ROLE_KEY=

# Postgres 직접 연결 (마이그레이션 러너 scripts/run-sql.mjs 용, 로컬 전용)
# 대시보드 > Project Settings > Database > Connection string (Session pooler)
SUPABASE_DB_URL=

# 웹 푸시 (VAPID) — npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:date245@naver.com

# 관리자 접근
# ADMIN_OPEN=true 면 누구나 /admin 접근 가능(개발용). 운영 전 반드시 false 또는 제거!
ADMIN_OPEN=false
# 콤마 구분 관리자 이메일 목록
ADMIN_EMAILS=date245@naver.com

# Gemini (홈 지역 타일 등 이미지 생성 스크립트용, 선택)
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────
# NHN KCP 결제 (연동 예정)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_KCP_SITE_CD=
KCP_SITE_KEY=
# 결제창/승인 도메인 (테스트: https://testspay.kcp.co.kr, 운영: https://spay.kcp.co.kr)
KCP_BASE_URL=https://testspay.kcp.co.kr

# 미설정 시 사이트는 mock 데이터 + 데모 결제로 동작합니다.
