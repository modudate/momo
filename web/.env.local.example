# ─────────────────────────────────────────────────────────────
# 모두의 모임 — 환경변수 (.env.local 로 복사해 값 입력)
# Vercel 배포 시: Project Settings > Environment Variables 에 동일하게 등록
# ─────────────────────────────────────────────────────────────

# Supabase (DB + 회원 인증) — 대시보드 > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 (절대 NEXT_PUBLIC_ 금지, 절대 커밋 금지)
SUPABASE_SERVICE_ROLE_KEY=

# Postgres 직접 연결 (마이그레이션 러너 scripts/run-sql.mjs 용, 로컬 전용)
# 대시보드 > Project Settings > Database > Connection string (Session pooler)
SUPABASE_DB_URL=

# 웹 푸시 (VAPID) — npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:date245@naver.com

# 관리자 접근
# 관리자 판별은 DB의 profiles.is_admin 으로 합니다 (회원의 is_admin 을 켜면 관리자).
# 아래는 웹푸시 수신 대상 등 보조 용도.
ADMIN_EMAILS=

# 네이버 지도 (지점 위치 링크)
NEXT_PUBLIC_NAVER_MAP_KEY_ID=
NAVER_MAP_CLIENT_SECRET=

# Gemini (홈 지역 타일 등 이미지 생성 스크립트용, 선택)
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────
# NHN KCP 결제 — 계약 후 KCP 기술관리센터에서 발급
#   인증서/개인키(PEM)는 여러 줄이라 .env 에 그대로 못 넣습니다.
#   base64 한 줄로 변환해서 넣으세요:
#     node scripts/kcp-pem-to-env.mjs <CERT.pem> <PRIKEY.pem>
#   키가 다 채워지기 전까지는 결제 미연동 상태로 동작합니다.
# ─────────────────────────────────────────────────────────────

# test = 테스트 결제(실제 결제 안 됨) / live = 실결제
# 테스트·운영 게이트웨이 주소는 코드에서 자동으로 갈라집니다 (URL 직접 설정 불필요)
KCP_MODE=test
NEXT_PUBLIC_KCP_MODE=test

# 사이트코드 (영문 대문자 5자리) — 결제창(브라우저)에도 필요해서 두 개
KCP_SITE_CD=
NEXT_PUBLIC_KCP_SITE_CD=

# 사이트키 (서버 전용 · 클라이언트 노출 금지)
KCP_SITE_KEY=

# 서비스 인증서 / 개인키 (PEM → base64 한 줄)
KCP_CERT_B64=
KCP_PRIKEY_B64=

# 개인키 비밀번호 (발급 시 설정했다면)
KCP_PRIKEY_PASSWORD=

# 미설정 시 사이트는 mock 데이터 + 결제 미연동 상태로 동작합니다.
