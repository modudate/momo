# ============================================================
# 환경변수 예시 — 실제 값은 .env.local 에 넣습니다 (이 파일은 값 없이 이름만).
# 배포(Vercel)에도 같은 값을 넣어야 동작합니다.
#   Vercel > 프로젝트 > Settings > Environment Variables
# ============================================================

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ---------- 관리자 ----------
# 관리자 판별은 DB의 profiles.is_admin 으로 합니다.
# (아래는 웹푸시 등 보조 용도. 관리자 추가는 회원의 is_admin 을 켜면 됩니다)
ADMIN_EMAILS=

# ---------- 웹푸시 (신청/취소 알림) ----------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ---------- 네이버 지도 ----------
NEXT_PUBLIC_NAVER_MAP_KEY_ID=
NAVER_MAP_CLIENT_SECRET=

# ---------- 이미지 생성 (지역 타일 제작용, 평상시 불필요) ----------
GEMINI_API_KEY=

# ============================================================
# KCP 결제 — 계약 후 KCP 기술관리센터에서 발급
#   인증서/개인키(PEM)는 여러 줄이라 base64 한 줄로 변환해 넣습니다:
#     node scripts/kcp-pem-to-env.mjs <CERT.pem> <PRIKEY.pem>
# ============================================================

# test = 테스트 결제(실제 결제 안 됨) / live = 실결제
KCP_MODE=test
NEXT_PUBLIC_KCP_MODE=test

# 사이트코드 (영문 대문자 5자리) — 결제창(브라우저)에도 필요
KCP_SITE_CD=
NEXT_PUBLIC_KCP_SITE_CD=

# 사이트키 (서버 전용 · 클라이언트 노출 금지)
KCP_SITE_KEY=

# 서비스 인증서 / 개인키 (PEM → base64 한 줄)
KCP_CERT_B64=
KCP_PRIKEY_B64=

# 개인키 비밀번호 (발급 시 설정했다면)
KCP_PRIKEY_PASSWORD=
